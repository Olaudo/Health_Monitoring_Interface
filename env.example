# VitalWatch — Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://vitalwatch:secret@localhost:5432/vitalwatch

# Redis
REDIS_URL=redis://localhost:6379

# Auth — CHANGE THIS before deploying to production
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRE_MINUTES=480

# App
APP_ENV=development
DEBUG=true
ALERT_POLL_INTERVAL=5
